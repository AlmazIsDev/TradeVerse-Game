{
  "name": "tradeverse",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && node node_modules/vite/bin/vite.js --port 20300",
    "dev:backend": "cd backend && python3 -m uvicorn main:app --reload --host 0.0.0.0 --port 20301",
    "start": "npm run dev",
    "install:all": "npm install && cd backend && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
