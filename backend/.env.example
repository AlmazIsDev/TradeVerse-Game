# ── TradeVerse backend configuration ────────────────────────────────────────
# Скопируйте в .env и заполните значения.

# База данных
MONGODB_URL=mongodb://localhost:27017

# Безопасность (обязательно смените в production)
JWT_SECRET=change-me-in-production
ADMIN_PASSWORD=change-me

# Срок жизни access-токена (JWT), минуты. Короткоживущий — безопаснее при утечке.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Срок жизни refresh-токена, дни. Скользящее окно: при каждой ротации отсчитывается заново.
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Реальные рыночные данные (MarketDataService) ────────────────────────────
# Криптовалюты: CoinGecko. Public API работает БЕЗ ключа.
# Demo-ключ (префикс "CG-") повышает лимиты бесплатно; Pro-ключ — платный.
COINGECKO_API_KEY=CG-hm4GsYP8ub3tN3vnjYW9Na2c
# План ключа: demo (по умолчанию) или pro. ВАЖНО: demo-ключ на Pro-эндпоинте
# возвращает 400 — для ключей "CG-..." оставляйте demo.
COINGECKO_API_PLAN=demo

# Акции: выберите один бесплатный провайдер и укажите ключ.
#   Finnhub    — https://finnhub.io  (бесплатный тариф, ключ обязателен)
#   Twelve Data— https://twelvedata.com (бесплатный тариф, 800 запросов/день)
FINNHUB_API_KEY=
TWELVEDATA_API_KEY=f0a07e3a62bb4aec8611e29f9d9a107f

# Как часто обновлять цены из внешних API (секунды). По умолчанию 120 (2 минуты).
MARKET_REFRESH_SECONDS=120
# Сколько монет тянуть из CoinGecko (топ по капитализации).
MARKET_CRYPTO_COUNT=50
